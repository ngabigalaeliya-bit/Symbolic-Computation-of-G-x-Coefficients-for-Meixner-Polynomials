(* ===Recurrence coefficients of Meixner polynomials===*)
Cn[n_, \[Beta]_, c_] := -(c*(\[Beta] + n - 1) + (n - 1))/(c - 1)
\[Lambda]n[n_, \[Beta]_, c_] := c*(n - 1)*(\[Beta] + n - 2)/(c - 1)^2

(* ===Evaluations M_{n-j}(-\[Beta]-s;\[Beta],c) for s=0,1,2 and j=1,2,\
3===*)
EvalMs[n_, j_, s_, \[Beta]_, c_] := 
 Pochhammer[\[Beta], n - j]/(c - 1)^(n - j)*
  Sum[Pochhammer[-(n - j), r]*
    Pochhammer[-s, r]/(Pochhammer[\[Beta], r]*r!)*(1 - c)^r, {r, 0, 
    Min[n - j, s]}]

(* ===Evaluation of M_n(-\[Beta]-s;\[Beta],c) using j=0===*)
MVal0[n_, s_, \[Beta]_, c_] := EvalMs[n, 0, s, \[Beta], c]

(* ===General evaluation matrix entry===*)
MVal[n_, j_, s_, \[Beta]_, c_] := EvalMs[n, j, s, \[Beta], c]

(* ===3x3 determinant with columns indexed by j1,j2,j3===*)
(*j=0 means M_n,j=1 means M_{n-1},j=2 means M_{n-2},j=3 means M_{n-3}*)
GetCol[j_, n_, \[Beta]_, c_] := 
 If[j == 0, {MVal0[n, 0, \[Beta], c], MVal0[n, 1, \[Beta], c], 
   MVal0[n, 2, \[Beta], c]}, {MVal[n, j, 0, \[Beta], c], 
   MVal[n, j, 1, \[Beta], c], MVal[n, j, 2, \[Beta], c]}]

Det3Full[j1_, j2_, j3_, n_, \[Beta]_, c_] := 
 Det[{GetCol[j1, n, \[Beta], c], GetCol[j2, n, \[Beta], c], 
   GetCol[j3, n, \[Beta], c]}]

(* ===Cofactors Q^{(3)}===*)
(*Q_{n-3}^{(3)}=-det(M_{n-2},M_{n-1},M_n)*)
Qn3[n_, \[Beta]_, c_] := -Det3Full[2, 1, 0, n, \[Beta], c]

(*Q_{n-2}^{(3)}=+det(M_{n-3},M_{n-1},M_n)*)
Qn2[n_, \[Beta]_, c_] := +Det3Full[3, 1, 0, n, \[Beta], c]

(*Q_{n-1}^{(3)}=-det(M_{n-3},M_{n-2},M_n)*)
Qn1[n_, \[Beta]_, c_] := -Det3Full[3, 2, 0, n, \[Beta], c]

(*V_{n-3,3}^{(3)}=Q_n^{(3)}=+det(M_{n-3},M_{n-2},M_{n-1})*)
V3[n_, \[Beta]_, c_] := +Det3Full[3, 2, 1, n, \[Beta], c]

(* ===Auxiliary polynomials===*)
S2[x_, n_, \[Beta]_, 
  c_] := (x - Cn[n - 1, \[Beta], c])*(x - 
     Cn[n, \[Beta], c]) - \[Lambda]n[n, \[Beta], c]

(* ===Expression of G2(x) with factor \[Beta](\[Beta]+1)(\[Beta]+\
2) in denominator===*)
G2[x_, n_, \[Beta]_, 
  c_] := (-1/(\[Beta]*(\[Beta] + 1)*(\[Beta] + 2)*
      V3[n, \[Beta], 
       c]))*((Qn3[n, \[Beta], 
        c]/(\[Lambda]n[n, \[Beta], c]*\[Lambda]n[n - 1, \[Beta], c]))*
     S2[x, n, \[Beta], 
      c] + (Qn2[n, \[Beta], c]/\[Lambda]n[n, \[Beta], c])*(x - 
       Cn[n, \[Beta], c]) + Qn1[n, \[Beta], c])

(* ===Expansion and extraction of coefficients===*)
G2expanded = Collect[FullSimplify[G2[x, n, \[Beta], c]], x]
A3 = FullSimplify[Coefficient[G2expanded, x, 2]]
B3 = FullSimplify[Coefficient[G2expanded, x, 1]]
D3 = FullSimplify[Coefficient[G2expanded, x, 0]]

(* ===Display===*)
Print["A3 = ", A3]
Print["B3 = ", B3]
Print["D3 = ", D3]
